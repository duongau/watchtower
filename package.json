{
  "name": "watchtower",
  "displayName": "Watchtower",
  "description": "Visual command center for monitoring AI agent squads inside VS Code",
  "version": "0.1.0",
  "publisher": "duongau",
  "license": "MIT",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "watchtower.openGraph",
        "title": "Open Agent Graph",
        "category": "Watchtower"
      },
      {
        "command": "watchtower.openMissionControl",
        "title": "Open Mission Control",
        "category": "Watchtower"
      },
      {
        "command": "watchtower.refreshAgents",
        "title": "Refresh Agents",
        "category": "Watchtower"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "watchtower",
          "title": "Watchtower",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "watchtower": [
        {
          "id": "watchtower.agents",
          "name": "Agents"
        },
        {
          "id": "watchtower.sessions",
          "name": "Sessions"
        },
        {
          "id": "watchtower.skills",
          "name": "Skills"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.100.0",
    "@vscode/vsce": "^3.0.0",
    "sharp": "^0.34.5",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@xyflow/react": "^12.6.0",
    "dagre": "^0.8.5",
    "lucide-react": "^1.8.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zustand": "^5.0.0"
  }
}
